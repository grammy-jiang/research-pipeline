{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RankedClusters",
  "description": "Schema for the ranked clusters output from the brief rank stage.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["cluster_id", "rank", "title", "items"],
    "properties": {
      "cluster_id": {"type": "string"},
      "rank":       {"type": "integer", "minimum": 1},
      "score":      {"type": "number"},
      "title":      {"type": "string", "minLength": 1},
      "summary":    {"type": "string"},
      "topics":     {"type": "array", "items": {"type": "string"}},
      "sources":    {"type": "array", "items": {"type": "string"}},
      "items": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["event_id", "source_id", "title"],
          "properties": {
            "event_id":  {"type": "string"},
            "source_id": {"type": "string"},
            "title":     {"type": "string"},
            "url":       {"type": "string"},
            "published": {"type": "string"}
          }
        }
      }
    }
  }
}
