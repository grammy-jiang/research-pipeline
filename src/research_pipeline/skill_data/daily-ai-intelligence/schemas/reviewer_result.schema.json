{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReviewerResult",
  "description": "Schema for reviewer gate results.",
  "type": "object",
  "required": ["reviewer_task_id", "target_artifact", "status"],
  "properties": {
    "reviewer_task_id":   {"type": "string"},
    "target_artifact":    {"type": "string"},
    "status":             {"type": "string", "enum": ["accepted", "rejected", "accepted_with_issues"]},
    "issues":             {"type": "array", "items": {"type": "string"}},
    "unsupported_claims": {"type": "array", "items": {"type": "string"}},
    "required_fixes":     {"type": "array", "items": {"type": "string"}},
    "confidence":         {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "notes":              {"type": "string"}
  }
}
