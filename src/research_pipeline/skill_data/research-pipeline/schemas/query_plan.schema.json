{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QueryPlan",
  "description": "Output schema for the research-pipeline plan stage.",
  "type": "object",
  "required": ["topic", "must_terms", "query_variants"],
  "properties": {
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "must_terms": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1,
      "maxItems": 3
    },
    "nice_terms": {
      "type": "array",
      "items": {"type": "string"}
    },
    "query_variants": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "arxiv_categories": {
      "type": "array",
      "items": {"type": "string"}
    },
    "date_range": {
      "type": "object",
      "properties": {
        "from": {"type": "string", "format": "date"},
        "to":   {"type": "string", "format": "date"}
      }
    }
  },
  "additionalProperties": true
}
